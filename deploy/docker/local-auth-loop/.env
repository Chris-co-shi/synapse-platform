# Synapse Gateway-IAM 本地认证闭环联调示例配置。
# 复制为 .env 后由 scripts/docker/prepare-local-auth-loop-env.sh 填充本地随机 secret。

SPRING_PROFILES_ACTIVE=dev
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0
TZ=UTC

POSTGRES_IMAGE=postgres:17
POSTGRES_HOST_PORT=5432
POSTGRES_DB=synapse_iam
POSTGRES_USER=synapse_iam
POSTGRES_PASSWORD=LPSHU/POppCkPa2dnC6XgSsqfWBp+qDl61nQSh99+fc1Bsh4

REDIS_IMAGE=redis:7.4
REDIS_HOST_PORT=6379
REDIS_PASSWORD=

NACOS_IMAGE=nacos/nacos-server:v3.0.3
NACOS_HOST_PORT=8848
NACOS_SERVER_ADDR=nacos:8848
NACOS_NAMESPACE=
NACOS_GROUP=SYNAPSE_PLATFORM_DEV
NACOS_USERNAME=
NACOS_PASSWORD=

IAM_SERVER_PORT=8100
IAM_HOST_PORT=18100
IAM_ISSUER_URI=http://iam:8100
IAM_JWK_SET_URI=http://iam:8100/oauth2/jwks
IAM_GATEWAY_PROOF_ENABLED=true
IAM_GATEWAY_PROOF_REPLAY_ENABLED=true
IAM_BOOTSTRAP_ENABLED=true
