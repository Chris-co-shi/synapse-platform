# 镜像 tag 必须明确且不可变；生产禁止使用 latest。
GATEWAY_IMAGE_REPOSITORY=registry.example.com/synapse/synapse-gateway
GATEWAY_IMAGE_TAG=0.1.0
GATEWAY_PULL_POLICY=always

SPRING_PROFILES_ACTIVE=prd
SERVER_PORT=20000
GATEWAY_HOST_PORT=20000

NACOS_SERVER_ADDR=nacos.example.com:8848
NACOS_NAMESPACE=
NACOS_GROUP=DEFAULT_GROUP
NACOS_USERNAME=
NACOS_PASSWORD=

IAM_ISSUER_URI=https://iam.example.com
IAM_JWK_SET_URI=https://iam.example.com/oauth2/jwks
SYNAPSE_GATEWAY_AUDIENCE=synapse-platform

GATEWAY_PROOF_ENABLED=true
GATEWAY_ID=synapse-gateway
# 必须由部署人员安全填写至少 32 UTF-8 字节的生产 secret；此文件不提供默认值。
GATEWAY_PROOF_SECRET=

JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0
TZ=UTC

SYNAPSE_DOCKER_NETWORK=synapse-platform

# 以下开关仅供无 Nacos 环境的本地容器演练覆盖，生产保持 true。
SPRING_CLOUD_NACOS_DISCOVERY_ENABLED=true
SPRING_CLOUD_NACOS_CONFIG_ENABLED=true
